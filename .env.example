# Copy to .env and fill in to enable live external services (USE_MOCKS=0).

BIND_ADDR=0.0.0.0:8080

# Store: omit DATABASE_URL to use the in-memory store (offline demo).
DATABASE_URL=postgres://scaffold:scaffold@localhost:5432/scaffold

# Set to 0 to use real Anki/AI/scraper/YouTube integrations.
USE_MOCKS=1

# AnkiConnect (desktop Anki add-on).
ANKI_ENDPOINT=http://localhost:8765

# AI (OpenAI-compatible chat completions).
AI_ENDPOINT=https://api.openai.com/v1/chat/completions
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Playwright scraping microservice.
SCRAPER_URL=http://localhost:9200/scrape

# YouTube Data API.
YOUTUBE_API_KEY=
